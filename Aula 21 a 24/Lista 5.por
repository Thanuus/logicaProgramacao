programa {
  funcao inicio() {
    cadeia nome
    real nota1, nota2, nota3, media
    escreva("Informe seu nome: ")
    leia(nome)
    escreva("Informe a priemira nota: ")
    leia(nota1)
    escreva("Informe a priemira nota: ")
    leia(nota2)
    escreva("Informe a priemira nota: ")
    leia(nota3)
    media = (nota1 + nota2 + nota3)/3
    escreva("Olá, ", nome, " seja bem vindo!")
    escreva("A media de suas notas é: ",media)
  }
}
