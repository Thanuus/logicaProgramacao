programa {
  funcao inicio() {
    inteiro valor1, valor2

    escreva("Digite um numero: ")
    leia(valor1)
    escreva("Digite um numero: ")
    leia(valor2)

    se (valor1 > valor2){
      escreva("Numero 1 é maior")
    } senao se (valor1 < valor2){
      escreva("Numero 2 é maior")
    } senao {
      escreva("Os valores sao iguais")
    }
    }
  }
}
